{
  "nav_html": "<!-- Meta Pixel Code -->\r\n<script>\r\n!function(f,b,e,v,n,t,s)\r\n{if(f.fbq)return;n=f.fbq=function(){n.callMethod?\r\nn.callMethod.apply(n,arguments):n.queue.push(arguments)};\r\nif(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';\r\nn.queue=[];t=b.createElement(e);t.async=!0;\r\nt.src=v;s=b.getElementsByTagName(e)[0];\r\ns.parentNode.insertBefore(t,s)}(window, document,'script',\r\n'https://connect.facebook.net/en_US/fbevents.js');\r\nfbq('init', '343231436269048');\r\nfbq('track', 'PageView');\r\n</script>\r\n<noscript><img height=\"1\" width=\"1\" style=\"display:none\"\r\nsrc=\"https://www.facebook.com/tr?id=343231436269048&ev=PageView&noscript=1\"\r\n/></noscript>\r\n<!-- End Meta Pixel Code -->\r\n\r\n\r\n<!-- ============================================================\r\n     TRAFFIC COP LABS — MEGA NAVIGATION (Shadow DOM Isolated)\r\n     \r\n     This component is fully encapsulated in a Shadow DOM.\r\n     No external CSS can interfere with it, and its styles\r\n     won't leak into your WordPress theme.\r\n     \r\n     Just paste this entire block wherever you want the nav.\r\n     ============================================================ -->\r\n\r\n<tcl-navbar></tcl-navbar>\r\n\r\n<script>\r\nclass TCLNavbar extends HTMLElement {\r\n  connectedCallback() {\r\n    const shadow = this.attachShadow({ mode: 'open' });\r\n\r\n    shadow.innerHTML = `\r\n      <style>\r\n        @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@400;500;600;700;800&display=swap');\r\n\r\n        /* ============================================================\r\n           RESET & VARIABLES — scoped to shadow root\r\n           ============================================================ */\r\n        *, *::before, *::after {\r\n          margin: 0;\r\n          padding: 0;\r\n          box-sizing: border-box;\r\n        }\r\n\r\n        :host {\r\n          display: block;\r\n          position: sticky;\r\n          top: 0;\r\n          z-index: 9999;\r\n          font-family: 'Outfit', system-ui, -apple-system, sans-serif;\r\n          font-size: 16px;\r\n          line-height: 1.5;\r\n          color: #1e293b;\r\n          -webkit-font-smoothing: antialiased;\r\n          -moz-osx-font-smoothing: grayscale;\r\n        }\r\n\r\n        a { color: inherit; text-decoration: none; }\r\n        button { font-family: inherit; }\r\n        img { display: block; }\r\n\r\n        /* ---- VARIABLES ---- */\r\n        :host {\r\n          --tcl-navy:        #1a2d42;\r\n          --tcl-blue:        #3a7ca5;\r\n          --tcl-orange:      #e8921b;\r\n          --tcl-orange-dark: #cf7e10;\r\n          --tcl-logo-cream:  #F2F2F2;\r\n          --tcl-logo-orange: #F5A623;\r\n          --tcl-white:       #ffffff;\r\n          --tcl-off-white:   #f7f8fa;\r\n          --tcl-border:      #e5e7eb;\r\n          --tcl-text:        #1e293b;\r\n          --tcl-text-mid:    #64748b;\r\n          --tcl-text-muted:  #94a3b8;\r\n          --tcl-nav-h:       72px;\r\n          --tcl-sidebar-w:   224px;\r\n          --tcl-max-w:       1280px;\r\n          --tcl-ease:        cubic-bezier(0.4, 0, 0.2, 1);\r\n          --tcl-fast:        0.18s;\r\n          --tcl-med:         0.25s;\r\n          --tcl-slow:        0.35s;\r\n        }\r\n\r\n        /* ---- BRAND STRIPE ---- */\r\n        .tcl-stripe {\r\n          height: 2px;\r\n          background: linear-gradient(90deg, var(--tcl-orange), var(--tcl-blue));\r\n          opacity: 0.6;\r\n        }\r\n\r\n        /* ---- NAVBAR BAR ---- */\r\n        .tcl-nav {\r\n          background: rgba(15, 20, 30, 0.92);\r\n          backdrop-filter: blur(12px);\r\n          -webkit-backdrop-filter: blur(12px);\r\n          height: var(--tcl-nav-h);\r\n          border-bottom: 1px solid rgba(255,255,255,0.08);\r\n          position: relative;\r\n          overflow: visible;\r\n        }\r\n\r\n        .tcl-nav__inner {\r\n          max-width: var(--tcl-max-w);\r\n          margin: 0 auto;\r\n          padding: 0 28px;\r\n          height: 100%;\r\n          display: flex;\r\n          align-items: center;\r\n        }\r\n\r\n        /* ---- TEXT LOGO ---- */\r\n        .tcl-nav__logo {\r\n          display: flex;\r\n          align-items: baseline;\r\n          text-decoration: none;\r\n          flex-shrink: 0;\r\n          margin-right: 44px;\r\n          font-family: 'Bebas Neue', sans-serif;\r\n          font-weight: 400;\r\n          font-size: 30px;\r\n          letter-spacing: 0.05em;\r\n          line-height: 1;\r\n          text-transform: uppercase;\r\n          white-space: nowrap;\r\n          -webkit-text-stroke: 0.5px currentColor;\r\n          transition: opacity var(--tcl-fast) var(--tcl-ease);\r\n        }\r\n\r\n        .tcl-nav__logo:hover {\r\n          opacity: 0.85;\r\n        }\r\n\r\n        .tcl-nav__logo-main {\r\n          color: var(--tcl-logo-cream);\r\n        }\r\n\r\n        .tcl-nav__logo-accent {\r\n          color: var(--tcl-logo-orange);\r\n          margin-left: 0.18em;\r\n        }\r\n\r\n        /* Desktop menu items */\r\n        .tcl-nav__menu {\r\n          display: flex;\r\n          align-items: center;\r\n          gap: 4px;\r\n        }\r\n\r\n        .tcl-nav__item {\r\n          display: flex;\r\n          align-items: center;\r\n          gap: 7px;\r\n          padding: 10px 20px;\r\n          font-size: 15px;\r\n          font-weight: 600;\r\n          color: rgba(255,255,255,0.85);\r\n          cursor: pointer;\r\n          border-radius: 8px;\r\n          transition: color var(--tcl-fast) var(--tcl-ease),\r\n                      background var(--tcl-fast) var(--tcl-ease);\r\n          user-select: none;\r\n          white-space: nowrap;\r\n        }\r\n\r\n        .tcl-nav__item:hover,\r\n        .tcl-nav__item.is-active {\r\n          color: var(--tcl-orange);\r\n          background: rgba(232,146,27,0.1);\r\n        }\r\n\r\n        .tcl-nav__item-chevron {\r\n          width: 11px;\r\n          height: 11px;\r\n          transition: transform var(--tcl-fast) var(--tcl-ease);\r\n          flex-shrink: 0;\r\n        }\r\n\r\n        .tcl-nav__item.is-active .tcl-nav__item-chevron {\r\n          transform: rotate(180deg);\r\n        }\r\n\r\n        /* Right actions */\r\n        .tcl-nav__actions {\r\n          margin-left: auto;\r\n          display: flex;\r\n          align-items: center;\r\n          gap: 12px;\r\n        }\r\n\r\n        .tcl-nav__login {\r\n          display: inline-flex;\r\n          align-items: center;\r\n          padding: 10px 24px;\r\n          font-size: 13.5px;\r\n          font-weight: 700;\r\n          letter-spacing: 0.6px;\r\n          color: rgba(255,255,255,0.9);\r\n          background: transparent;\r\n          border: 1.5px solid rgba(255,255,255,0.35);\r\n          border-radius: 8px;\r\n          text-decoration: none;\r\n          cursor: pointer;\r\n          transition: background var(--tcl-fast) var(--tcl-ease),\r\n                      border-color var(--tcl-fast) var(--tcl-ease),\r\n                      color var(--tcl-fast) var(--tcl-ease),\r\n                      transform 0.12s ease;\r\n          white-space: nowrap;\r\n        }\r\n\r\n        .tcl-nav__login:hover {\r\n          background: rgba(255,255,255,0.08);\r\n          border-color: var(--tcl-orange);\r\n          color: var(--tcl-orange);\r\n          transform: translateY(-1px);\r\n        }\r\n\r\n        /* Hamburger */\r\n        .tcl-nav__burger {\r\n          display: none;\r\n          background: none;\r\n          border: none;\r\n          cursor: pointer;\r\n          padding: 8px;\r\n          margin-left: 16px;\r\n          -webkit-tap-highlight-color: transparent;\r\n        }\r\n\r\n        .tcl-nav__burger-line {\r\n          display: block;\r\n          width: 24px;\r\n          height: 2.5px;\r\n          background: var(--tcl-white);\r\n          border-radius: 2px;\r\n          transition: transform var(--tcl-slow) var(--tcl-ease),\r\n                      opacity var(--tcl-med) var(--tcl-ease);\r\n        }\r\n\r\n        .tcl-nav__burger-line + .tcl-nav__burger-line { margin-top: 5px; }\r\n\r\n        .tcl-nav__burger.is-open .tcl-nav__burger-line:nth-child(1) {\r\n          transform: translateY(7.5px) rotate(45deg);\r\n        }\r\n        .tcl-nav__burger.is-open .tcl-nav__burger-line:nth-child(2) {\r\n          opacity: 0;\r\n        }\r\n        .tcl-nav__burger.is-open .tcl-nav__burger-line:nth-child(3) {\r\n          transform: translateY(-7.5px) rotate(-45deg);\r\n        }\r\n\r\n        /* ---- MEGA DROPDOWN ---- */\r\n        .tcl-mega {\r\n          position: absolute;\r\n          top: 100%;\r\n          left: 0;\r\n          right: 0;\r\n          background: var(--tcl-white);\r\n          box-shadow: 0 8px 40px rgba(0,0,0,0.10), 0 1px 3px rgba(0,0,0,0.06);\r\n          opacity: 0;\r\n          visibility: hidden;\r\n          transform: translateY(-6px);\r\n          transition: opacity var(--tcl-med) var(--tcl-ease),\r\n                      transform var(--tcl-med) var(--tcl-ease),\r\n                      visibility var(--tcl-med);\r\n          pointer-events: none;\r\n        }\r\n\r\n        .tcl-mega.is-open {\r\n          opacity: 1;\r\n          visibility: visible;\r\n          transform: translateY(0);\r\n          pointer-events: auto;\r\n        }\r\n\r\n        .tcl-mega__inner {\r\n          max-width: var(--tcl-max-w);\r\n          margin: 0 auto;\r\n          display: flex;\r\n          min-height: 240px;\r\n        }\r\n\r\n        /* Sidebar */\r\n        .tcl-mega__sidebar {\r\n          width: var(--tcl-sidebar-w);\r\n          flex-shrink: 0;\r\n          background: var(--tcl-off-white);\r\n          border-right: 1px solid var(--tcl-border);\r\n          padding: 20px 0;\r\n        }\r\n\r\n        .tcl-mega__side-item {\r\n          display: flex;\r\n          align-items: center;\r\n          justify-content: space-between;\r\n          padding: 13px 28px;\r\n          font-size: 15px;\r\n          font-weight: 500;\r\n          color: var(--tcl-text);\r\n          cursor: pointer;\r\n          border-left: 3px solid transparent;\r\n          transition: all var(--tcl-fast) var(--tcl-ease);\r\n        }\r\n\r\n        .tcl-mega__side-item:hover {\r\n          background: rgba(0,0,0,0.025);\r\n        }\r\n\r\n        .tcl-mega__side-item.is-active {\r\n          background: var(--tcl-white);\r\n          border-left-color: var(--tcl-orange);\r\n          color: var(--tcl-orange);\r\n          font-weight: 600;\r\n        }\r\n\r\n        .tcl-mega__side-chevron {\r\n          width: 13px;\r\n          height: 13px;\r\n          opacity: 0.35;\r\n          transition: opacity var(--tcl-fast) var(--tcl-ease),\r\n                      transform var(--tcl-fast) var(--tcl-ease);\r\n          flex-shrink: 0;\r\n        }\r\n\r\n        .tcl-mega__side-item.is-active .tcl-mega__side-chevron {\r\n          opacity: 0.7;\r\n          transform: translateX(2px);\r\n        }\r\n\r\n        /* Content area */\r\n        .tcl-mega__content {\r\n          flex: 1;\r\n          padding: 32px 44px 36px;\r\n        }\r\n\r\n        .tcl-mega__section-label {\r\n          font-size: 11.5px;\r\n          font-weight: 700;\r\n          text-transform: uppercase;\r\n          letter-spacing: 1.4px;\r\n          color: var(--tcl-text-muted);\r\n          margin-bottom: 20px;\r\n          padding-bottom: 14px;\r\n          border-bottom: 1px solid var(--tcl-border);\r\n        }\r\n\r\n        .tcl-mega__grid {\r\n          display: grid;\r\n          grid-template-columns: repeat(2, 1fr);\r\n          gap: 6px;\r\n        }\r\n\r\n        .tcl-mega__card {\r\n          display: block;\r\n          padding: 16px 20px;\r\n          border-radius: 10px;\r\n          text-decoration: none;\r\n          transition: background var(--tcl-fast) var(--tcl-ease);\r\n        }\r\n\r\n        .tcl-mega__card:hover {\r\n          background: var(--tcl-off-white);\r\n        }\r\n\r\n        .tcl-mega__card-title {\r\n          font-size: 15px;\r\n          font-weight: 600;\r\n          color: var(--tcl-text);\r\n          margin-bottom: 4px;\r\n          transition: color var(--tcl-fast) var(--tcl-ease);\r\n          display: flex;\r\n          align-items: center;\r\n          gap: 8px;\r\n          flex-wrap: wrap;\r\n        }\r\n\r\n        .tcl-mega__card:hover .tcl-mega__card-title {\r\n          color: var(--tcl-orange);\r\n        }\r\n\r\n        .tcl-mega__card-desc {\r\n          font-size: 13px;\r\n          font-weight: 400;\r\n          color: var(--tcl-text-mid);\r\n          line-height: 1.45;\r\n        }\r\n\r\n        .tcl-badge {\r\n          display: inline-block;\r\n          padding: 2px 8px;\r\n          font-size: 10px;\r\n          font-weight: 800;\r\n          letter-spacing: 0.6px;\r\n          background: #10b981;\r\n          color: var(--tcl-white);\r\n          border-radius: 4px;\r\n          line-height: 1.4;\r\n        }\r\n\r\n        .tcl-badge--soon {\r\n          background: linear-gradient(135deg, #f59e0b, #d97706);\r\n        }\r\n\r\n        .tcl-mega__content-inner {\r\n          animation: tclSlideIn var(--tcl-fast) var(--tcl-ease);\r\n        }\r\n\r\n        @keyframes tclSlideIn {\r\n          from { opacity: 0; transform: translateX(6px); }\r\n          to   { opacity: 1; transform: translateX(0); }\r\n        }\r\n\r\n        /* ---- OVERLAY ---- */\r\n        .tcl-overlay {\r\n          position: fixed;\r\n          inset: 0;\r\n          background: rgba(15, 23, 42, 0.12);\r\n          opacity: 0;\r\n          visibility: hidden;\r\n          transition: opacity var(--tcl-med) var(--tcl-ease), visibility var(--tcl-med);\r\n          z-index: -1;\r\n        }\r\n\r\n        .tcl-overlay.is-open {\r\n          opacity: 1;\r\n          visibility: visible;\r\n        }\r\n\r\n        /* ---- MOBILE DRAWER ---- */\r\n        .tcl-mob-bg {\r\n          position: fixed;\r\n          inset: 0;\r\n          background: rgba(15, 23, 42, 0.45);\r\n          opacity: 0;\r\n          visibility: hidden;\r\n          transition: opacity var(--tcl-med) var(--tcl-ease), visibility var(--tcl-med);\r\n          z-index: 100;\r\n        }\r\n\r\n        .tcl-mob-bg.is-open {\r\n          opacity: 1;\r\n          visibility: visible;\r\n        }\r\n\r\n        .tcl-mob {\r\n          position: fixed;\r\n          top: 0;\r\n          right: 0;\r\n          width: 100%;\r\n          max-width: 420px;\r\n          height: 100dvh;\r\n          background: var(--tcl-white);\r\n          z-index: 101;\r\n          transform: translateX(100%);\r\n          transition: transform var(--tcl-slow) var(--tcl-ease);\r\n          overflow-y: auto;\r\n          overscroll-behavior: contain;\r\n          box-shadow: -6px 0 32px rgba(0,0,0,0.12);\r\n        }\r\n\r\n        .tcl-mob.is-open {\r\n          transform: translateX(0);\r\n        }\r\n\r\n        .tcl-mob__head {\r\n          display: flex;\r\n          align-items: center;\r\n          justify-content: space-between;\r\n          padding: 16px 24px;\r\n          border-bottom: 1px solid var(--tcl-border);\r\n        }\r\n\r\n        .tcl-mob__head-logo {\r\n          font-family: 'Bebas Neue', sans-serif;\r\n          font-weight: 400;\r\n          font-size: 24px;\r\n          letter-spacing: 0.05em;\r\n          line-height: 1;\r\n          text-transform: uppercase;\r\n          white-space: nowrap;\r\n          text-decoration: none;\r\n          display: flex;\r\n          align-items: baseline;\r\n          -webkit-text-stroke: 0.5px currentColor;\r\n        }\r\n\r\n        .tcl-mob__head-logo .logo-main {\r\n          color: var(--tcl-text);\r\n        }\r\n\r\n        .tcl-mob__head-logo .logo-accent {\r\n          color: var(--tcl-logo-orange);\r\n          margin-left: 0.18em;\r\n        }\r\n\r\n        .tcl-mob__close {\r\n          background: none;\r\n          border: none;\r\n          cursor: pointer;\r\n          padding: 8px;\r\n          color: var(--tcl-text-mid);\r\n          transition: color var(--tcl-fast);\r\n          -webkit-tap-highlight-color: transparent;\r\n        }\r\n\r\n        .tcl-mob__close:hover { color: var(--tcl-text); }\r\n        .tcl-mob__close svg { width: 24px; height: 24px; display: block; }\r\n\r\n        .tcl-mob__acc {\r\n          border-bottom: 1px solid var(--tcl-border);\r\n        }\r\n\r\n        .tcl-mob__acc-trigger {\r\n          display: flex;\r\n          align-items: center;\r\n          justify-content: space-between;\r\n          width: 100%;\r\n          padding: 18px 24px;\r\n          background: none;\r\n          border: none;\r\n          font-family: 'Outfit', system-ui, sans-serif;\r\n          font-size: 16px;\r\n          font-weight: 600;\r\n          color: var(--tcl-text);\r\n          cursor: pointer;\r\n          text-align: left;\r\n          -webkit-tap-highlight-color: transparent;\r\n          transition: color var(--tcl-fast);\r\n        }\r\n\r\n        .tcl-mob__acc-trigger.is-open {\r\n          color: var(--tcl-orange);\r\n        }\r\n\r\n        .tcl-mob__acc-trigger svg {\r\n          width: 16px;\r\n          height: 16px;\r\n          flex-shrink: 0;\r\n          transition: transform var(--tcl-slow) var(--tcl-ease);\r\n        }\r\n\r\n        .tcl-mob__acc-trigger.is-open svg {\r\n          transform: rotate(180deg);\r\n        }\r\n\r\n        .tcl-mob__acc-body {\r\n          max-height: 0;\r\n          overflow: hidden;\r\n          transition: max-height var(--tcl-slow) var(--tcl-ease);\r\n        }\r\n\r\n        .tcl-mob__group {\r\n          padding: 0 24px 12px;\r\n        }\r\n\r\n        .tcl-mob__group-label {\r\n          font-size: 11px;\r\n          font-weight: 700;\r\n          text-transform: uppercase;\r\n          letter-spacing: 1.3px;\r\n          color: var(--tcl-text-muted);\r\n          padding: 14px 0 8px;\r\n        }\r\n\r\n        .tcl-mob__link {\r\n          display: block;\r\n          padding: 10px 0;\r\n          text-decoration: none;\r\n          border-bottom: 1px solid rgba(0,0,0,0.04);\r\n        }\r\n\r\n        .tcl-mob__link:last-child { border-bottom: none; }\r\n\r\n        .tcl-mob__link-title {\r\n          font-size: 14px;\r\n          font-weight: 600;\r\n          color: var(--tcl-text);\r\n          display: flex;\r\n          align-items: center;\r\n          gap: 6px;\r\n        }\r\n\r\n        .tcl-mob__link-desc {\r\n          font-size: 12px;\r\n          color: var(--tcl-text-mid);\r\n          margin-top: 2px;\r\n          line-height: 1.4;\r\n        }\r\n\r\n        .tcl-mob__foot {\r\n          padding: 24px;\r\n          margin-top: 8px;\r\n          display: flex;\r\n          flex-direction: column;\r\n          gap: 12px;\r\n        }\r\n\r\n        .tcl-mob__foot .tcl-nav__login {\r\n          display: block;\r\n          text-align: center;\r\n          width: 100%;\r\n          padding: 14px 24px;\r\n          font-size: 14px;\r\n          color: var(--tcl-white);\r\n          background: var(--tcl-orange);\r\n          border-color: var(--tcl-orange);\r\n        }\r\n\r\n        .tcl-mob__foot .tcl-nav__login:hover {\r\n          background: var(--tcl-orange-dark);\r\n          border-color: var(--tcl-orange-dark);\r\n          color: var(--tcl-white);\r\n        }\r\n\r\n        /* RESPONSIVE */\r\n        @media (max-width: 960px) {\r\n          .tcl-nav__menu,\r\n          .tcl-nav__actions { display: none; }\r\n          .tcl-nav__burger  { display: block; }\r\n          .tcl-mega, .tcl-overlay { display: none !important; }\r\n        }\r\n\r\n        @media (max-width: 480px) {\r\n          .tcl-mob { max-width: 100%; }\r\n          .tcl-nav__logo { font-size: 24px; margin-right: 16px; }\r\n        }\r\n      </style>\r\n\r\n      <!-- OVERLAY -->\r\n      <div class=\"tcl-overlay\" id=\"tclOverlay\"></div>\r\n\r\n      <!-- STRIPE -->\r\n      <div class=\"tcl-stripe\"></div>\r\n\r\n      <!-- NAVBAR -->\r\n      <nav class=\"tcl-nav\" role=\"navigation\" aria-label=\"Main navigation\">\r\n        <div class=\"tcl-nav__inner\">\r\n\r\n          <a href=\"/\" class=\"tcl-nav__logo\" aria-label=\"Traffic Cop Labs Home\">\r\n            <span class=\"tcl-nav__logo-main\">TRAFFIC COP</span>\r\n            <span class=\"tcl-nav__logo-accent\">LABS</span>\r\n          </a>\r\n\r\n          <div class=\"tcl-nav__menu\" id=\"tclMenu\">\r\n            <div class=\"tcl-nav__item\" data-menu=\"training\" role=\"button\" tabindex=\"0\" aria-haspopup=\"true\" aria-expanded=\"false\">\r\n              Training\r\n              <svg class=\"tcl-nav__item-chevron\" viewBox=\"0 0 12 12\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M3 4.5L6 7.5L9 4.5\"/></svg>\r\n            </div>\r\n            <div class=\"tcl-nav__item\" data-menu=\"hardware\" role=\"button\" tabindex=\"0\" aria-haspopup=\"true\" aria-expanded=\"false\">\r\n              Hardware\r\n              <svg class=\"tcl-nav__item-chevron\" viewBox=\"0 0 12 12\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M3 4.5L6 7.5L9 4.5\"/></svg>\r\n            </div>\r\n            <div class=\"tcl-nav__item\" data-menu=\"software\" role=\"button\" tabindex=\"0\" aria-haspopup=\"true\" aria-expanded=\"false\">\r\n              Software\r\n              <svg class=\"tcl-nav__item-chevron\" viewBox=\"0 0 12 12\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M3 4.5L6 7.5L9 4.5\"/></svg>\r\n            </div>\r\n          </div>\r\n\r\n          <div class=\"tcl-nav__actions\">\r\n            <a href=\"https://software.trafficcoplabs.com\" class=\"tcl-nav__login\">SOFTWARE LOGIN</a>\r\n            <a href=\"https://training.trafficcoplabs.com\" class=\"tcl-nav__login\">TRAINING LOGIN</a>\r\n          </div>\r\n\r\n          <button class=\"tcl-nav__burger\" id=\"tclBurger\" aria-label=\"Open menu\">\r\n            <span class=\"tcl-nav__burger-line\"></span>\r\n            <span class=\"tcl-nav__burger-line\"></span>\r\n            <span class=\"tcl-nav__burger-line\"></span>\r\n          </button>\r\n\r\n        </div>\r\n\r\n        <!-- MEGA DROPDOWN -->\r\n        <div class=\"tcl-mega\" id=\"tclMega\" role=\"region\" aria-label=\"Submenu\">\r\n          <div class=\"tcl-mega__inner\">\r\n            <div class=\"tcl-mega__sidebar\" id=\"tclSidebar\"></div>\r\n            <div class=\"tcl-mega__content\" id=\"tclContent\"></div>\r\n          </div>\r\n        </div>\r\n      </nav>\r\n\r\n      <!-- MOBILE DRAWER -->\r\n      <div class=\"tcl-mob-bg\" id=\"tclMobBg\"></div>\r\n      <div class=\"tcl-mob\" id=\"tclMob\">\r\n        <div class=\"tcl-mob__head\">\r\n          <a href=\"/\" class=\"tcl-mob__head-logo\">\r\n            <span class=\"logo-main\">TRAFFIC COP</span>\r\n            <span class=\"logo-accent\">LABS</span>\r\n          </a>\r\n          <button class=\"tcl-mob__close\" id=\"tclMobClose\" aria-label=\"Close menu\">\r\n            <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\"><path d=\"M18 6L6 18M6 6l12 12\"/></svg>\r\n          </button>\r\n        </div>\r\n        <div class=\"tcl-mob__nav\" id=\"tclMobNav\"></div>\r\n        <div class=\"tcl-mob__foot\">\r\n          <a href=\"https://software.trafficcoplabs.com\" class=\"tcl-nav__login\">SOFTWARE LOGIN</a>\r\n          <a href=\"https://training.trafficcoplabs.com\" class=\"tcl-nav__login\">TRAINING LOGIN</a>\r\n        </div>\r\n      </div>\r\n    `;\r\n\r\n    /* ================================================================\r\n       JAVASCRIPT — runs inside shadow root\r\n       ================================================================ */\r\n\r\n    const MENU = {\r\n      training: {\r\n        label: 'Training',\r\n        sections: [\r\n          { id: 'uas', label: 'UAS', links: [\r\n            { title: 'READY 107', desc: 'FAA Remote Pilot Test Prep', url: 'https://trafficcoplabs.com/ready107' },\r\n            { title: 'Fundamentals of Drone Mapping', desc: 'Map Incident Scenes with Drones', url: 'https://trafficcoplabs.com/fundamentals' }\r\n          ]},\r\n          { id: 'recon', label: 'Recon', links: [\r\n            { title: 'Occupant Kinematics', desc: 'Solve the \"Who Was Driving?\" Case', url: 'https://trafficcoplabs.com/occupantkinematics' },\r\n            { title: 'Crash EVAL', desc: 'Analyze and Investigate Impaired Driving Crashes', url: 'https://trafficcoplabs.com/crasheval' },\r\n            { title: 'Auto 101', desc: 'Automotive Knowledge for the Crash Investigator', url: 'https://trafficcoplabs.com/auto101' },\r\n            { title: 'Ped-Bike Crash Analysis', desc: 'Investigate Crashes Involving Pedestrians & Bicycles', url: 'https://trafficcoplabs.com/pedbike' }\r\n          ]},\r\n          { id: 'crime-scene', label: 'Crime Scene', links: [\r\n            { title: 'Weaponized Vehicle', desc: 'Investigating Crimes Involving Vehicles as a Weapon', url: 'https://trafficcoplabs.com/weaponized-vehicle' }\r\n          ]},\r\n          { id: 'in-person', label: 'In-Person', links: [\r\n            { title: 'Training Calendar', desc: 'Check Out Our In-Person Calendar', url: 'https://trafficcoplabs.com/calendar' },\r\n            { title: 'Host a Class', desc: 'Bring Traffic Cop Labs to Your Agency', url: 'https://trafficcoplabs.com/host' }\r\n          ]}\r\n        ]\r\n      },\r\n      hardware: {\r\n        label: 'Hardware',\r\n        sections: [\r\n          { id: 'gnss', label: 'GNSS', links: [\r\n            { title: 'TCL Fusion Rover', desc: 'Entry Level GNSS Mapping', url: 'https://trafficcoplabs.com/fusion' },\r\n            { title: 'GeoMate SG6', desc: 'GNSS Mapping with Visual Stakeout', url: 'https://trafficcoplabs.com/sg6' },\r\n            { title: 'GeoMate SG7', desc: 'Best for Mapping Under Tree Canopy', url: 'https://trafficcoplabs.com/sg7' }\r\n          ]},\r\n          { id: 'friction', label: 'Friction Testing', links: [\r\n            { title: 'IntelliSLED', desc: 'Get Better Data from Your Drag Sled', badge: 'COMING SOON', badgeClass: 'tcl-badge--soon', url: '#' }\r\n          ]}\r\n        ]\r\n      },\r\n      software: {\r\n        label: 'Software',\r\n        sections: [\r\n          { id: 'photogrammetry', label: 'Photogrammetry', links: [\r\n            { title: 'PhotoModeler', desc: 'Solve Inverse Camera, Diagram Crush, Process Drone Images & Point Clouds', url: 'https://trafficcoplabs.com/photomodeler' }\r\n          ]},\r\n          { id: 'recon-sw', label: 'Recon', links: [\r\n            { title: 'PedStrikePRO', desc: 'Calculate Ped-Bike Involved Crashes', url: 'https://trafficcoplabs.com/pedstrikepro' },\r\n            { title: 'VINSights', desc: 'Decode VINs and Check Recalls through NHTSA', badge: 'FREE', url: 'https://trafficcoplabs.com/vinsights' }\r\n          ]},\r\n          { id: 'video', label: 'Video Analysis', links: [\r\n            { title: 'ChronoSnap', desc: \"The World's Only Analysis Program Built for Crash Investigations\", url: 'https://trafficcoplabs.com/chronosnap' }\r\n          ]}\r\n        ]\r\n      }\r\n    };\r\n\r\n    const root      = shadow;\r\n    const $mega     = root.getElementById('tclMega');\r\n    const $sidebar  = root.getElementById('tclSidebar');\r\n    const $content  = root.getElementById('tclContent');\r\n    const $overlay  = root.getElementById('tclOverlay');\r\n    const $burger   = root.getElementById('tclBurger');\r\n    const $mob      = root.getElementById('tclMob');\r\n    const $mobBg    = root.getElementById('tclMobBg');\r\n    const $mobNav   = root.getElementById('tclMobNav');\r\n    const $mobClose = root.getElementById('tclMobClose');\r\n    const $navItems = root.querySelectorAll('.tcl-nav__item');\r\n\r\n    let closeTimer    = null;\r\n    let activeMenu    = null;\r\n    let activeSection = null;\r\n\r\n    const chevronRight = '<svg class=\"tcl-mega__side-chevron\" viewBox=\"0 0 14 14\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M5 3l4 4-4 4\"/></svg>';\r\n\r\n    function openMega(menuKey) {\r\n      if (activeMenu === menuKey) return;\r\n      activeMenu = menuKey;\r\n      activeSection = null;\r\n      $navItems.forEach(el => {\r\n        const isTarget = el.dataset.menu === menuKey;\r\n        el.classList.toggle('is-active', isTarget);\r\n        el.setAttribute('aria-expanded', isTarget);\r\n      });\r\n      const menu = MENU[menuKey];\r\n      $sidebar.innerHTML = menu.sections.map((s, i) =>\r\n        '<div class=\"tcl-mega__side-item' + (i === 0 ? ' is-active' : '') + '\" data-section=\"' + s.id + '\">' + s.label + chevronRight + '</div>'\r\n      ).join('');\r\n      $sidebar.querySelectorAll('.tcl-mega__side-item').forEach(el => {\r\n        el.addEventListener('mouseenter', () => setSection(menuKey, el.dataset.section));\r\n      });\r\n      setSection(menuKey, menu.sections[0].id);\r\n      $mega.classList.add('is-open');\r\n      $overlay.classList.add('is-open');\r\n    }\r\n\r\n    function setSection(menuKey, sectionId) {\r\n      if (activeSection === sectionId) return;\r\n      activeSection = sectionId;\r\n      $sidebar.querySelectorAll('.tcl-mega__side-item').forEach(el => {\r\n        el.classList.toggle('is-active', el.dataset.section === sectionId);\r\n      });\r\n      const section = MENU[menuKey].sections.find(s => s.id === sectionId);\r\n      if (!section) return;\r\n      const cards = section.links.map(link => {\r\n        let badge = '';\r\n        if (link.badge) {\r\n          const badgeClass = link.badgeClass ? 'tcl-badge ' + link.badgeClass : 'tcl-badge';\r\n          badge = '<span class=\"' + badgeClass + '\">' + link.badge + '</span>';\r\n        }\r\n        return '<a href=\"' + link.url + '\" class=\"tcl-mega__card\"><div class=\"tcl-mega__card-title\">' + link.title + badge + '</div><div class=\"tcl-mega__card-desc\">' + link.desc + '</div></a>';\r\n      }).join('');\r\n      $content.innerHTML = '<div class=\"tcl-mega__content-inner\"><div class=\"tcl-mega__section-label\">' + section.label + '</div><div class=\"tcl-mega__grid\">' + cards + '</div></div>';\r\n    }\r\n\r\n    function closeMega() {\r\n      activeMenu = null;\r\n      activeSection = null;\r\n      $mega.classList.remove('is-open');\r\n      $overlay.classList.remove('is-open');\r\n      $navItems.forEach(el => {\r\n        el.classList.remove('is-active');\r\n        el.setAttribute('aria-expanded', 'false');\r\n      });\r\n    }\r\n\r\n    function startCloseTimer() { clearTimeout(closeTimer); closeTimer = setTimeout(closeMega, 220); }\r\n    function cancelCloseTimer() { clearTimeout(closeTimer); }\r\n\r\n    $navItems.forEach(el => {\r\n      el.addEventListener('mouseenter', () => { cancelCloseTimer(); openMega(el.dataset.menu); });\r\n      el.addEventListener('mouseleave', startCloseTimer);\r\n      el.addEventListener('keydown', e => {\r\n        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); activeMenu === el.dataset.menu ? closeMega() : openMega(el.dataset.menu); }\r\n        if (e.key === 'Escape') closeMega();\r\n      });\r\n    });\r\n\r\n    $mega.addEventListener('mouseenter', cancelCloseTimer);\r\n    $mega.addEventListener('mouseleave', startCloseTimer);\r\n    $overlay.addEventListener('click', closeMega);\r\n    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeMega(); });\r\n\r\n    /* MOBILE */\r\n    function buildMobileNav() {\r\n      let html = '';\r\n      for (const [key, menu] of Object.entries(MENU)) {\r\n        const chevDown = '<svg viewBox=\"0 0 16 16\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\"><path d=\"M4 6l4 4 4-4\"/></svg>';\r\n        let body = '';\r\n        menu.sections.forEach(section => {\r\n          body += '<div class=\"tcl-mob__group\"><div class=\"tcl-mob__group-label\">' + section.label + '</div>';\r\n          section.links.forEach(link => {\r\n            let badge = '';\r\n            if (link.badge) {\r\n              const badgeClass = link.badgeClass ? 'tcl-badge ' + link.badgeClass : 'tcl-badge';\r\n              badge = '<span class=\"' + badgeClass + '\">' + link.badge + '</span>';\r\n            }\r\n            body += '<a href=\"' + link.url + '\" class=\"tcl-mob__link\"><div class=\"tcl-mob__link-title\">' + link.title + badge + '</div><div class=\"tcl-mob__link-desc\">' + link.desc + '</div></a>';\r\n          });\r\n          body += '</div>';\r\n        });\r\n        html += '<div class=\"tcl-mob__acc\"><button class=\"tcl-mob__acc-trigger\" data-menu=\"' + key + '\">' + menu.label + chevDown + '</button><div class=\"tcl-mob__acc-body\">' + body + '</div></div>';\r\n      }\r\n      $mobNav.innerHTML = html;\r\n      $mobNav.querySelectorAll('.tcl-mob__acc-trigger').forEach(trigger => {\r\n        trigger.addEventListener('click', () => {\r\n          const body = trigger.nextElementSibling;\r\n          const isOpen = trigger.classList.contains('is-open');\r\n          $mobNav.querySelectorAll('.tcl-mob__acc-trigger').forEach(t => {\r\n            t.classList.remove('is-open');\r\n            t.nextElementSibling.style.maxHeight = '0';\r\n          });\r\n          if (!isOpen) {\r\n            trigger.classList.add('is-open');\r\n            body.style.maxHeight = body.scrollHeight + 'px';\r\n          }\r\n        });\r\n      });\r\n    }\r\n\r\n    function openMobile() {\r\n      $mob.classList.add('is-open');\r\n      $mobBg.classList.add('is-open');\r\n      $burger.classList.add('is-open');\r\n      document.body.style.overflow = 'hidden';\r\n    }\r\n\r\n    function closeMobile() {\r\n      $mob.classList.remove('is-open');\r\n      $mobBg.classList.remove('is-open');\r\n      $burger.classList.remove('is-open');\r\n      document.body.style.overflow = '';\r\n    }\r\n\r\n    $burger.addEventListener('click', () => { $mob.classList.contains('is-open') ? closeMobile() : openMobile(); });\r\n    $mobClose.addEventListener('click', closeMobile);\r\n    $mobBg.addEventListener('click', closeMobile);\r\n    buildMobileNav();\r\n  }\r\n}\r\n\r\ncustomElements.define('tcl-navbar', TCLNavbar);\r\n</script>",
  "footer_html": "<!-- ============================================================\r\n     TRAFFIC COP LABS — FOOTER (Shadow DOM Isolated)\r\n     \r\n     This component is fully encapsulated in a Shadow DOM.\r\n     No external CSS can interfere with it, and its styles\r\n     won't leak into your WordPress theme.\r\n     \r\n     Just paste this entire block wherever you want the footer.\r\n     ============================================================ -->\r\n\r\n<tcl-footer></tcl-footer>\r\n\r\n<script>\r\nclass TCLFooter extends HTMLElement {\r\n  connectedCallback() {\r\n    const shadow = this.attachShadow({ mode: 'open' });\r\n\r\n    shadow.innerHTML = `\r\n      <style>\r\n        @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@400;500;600;700;800&display=swap');\r\n\r\n        /* ============================================================\r\n           RESET & VARIABLES\r\n           ============================================================ */\r\n        *, *::before, *::after {\r\n          margin: 0;\r\n          padding: 0;\r\n          box-sizing: border-box;\r\n        }\r\n\r\n        :host {\r\n          display: block;\r\n          font-family: 'Outfit', system-ui, -apple-system, sans-serif;\r\n          font-size: 16px;\r\n          line-height: 1.5;\r\n          -webkit-font-smoothing: antialiased;\r\n          -moz-osx-font-smoothing: grayscale;\r\n        }\r\n\r\n        a { color: inherit; text-decoration: none; }\r\n\r\n        /* ---- VARIABLES ---- */\r\n        :host {\r\n          --tcl-orange:      #e8921b;\r\n          --tcl-orange-glow: rgba(232, 146, 27, 0.4);\r\n          --tcl-logo-cream:  #F2F2F2;\r\n          --tcl-logo-orange: #F5A623;\r\n          --tcl-white:       #ffffff;\r\n          --tcl-text-muted:  rgba(255, 255, 255, 0.6);\r\n          --tcl-ease:        cubic-bezier(0.4, 0, 0.2, 1);\r\n          --tcl-fast:        0.18s;\r\n        }\r\n\r\n        /* ============================================================\r\n           FOOTER STRUCTURE\r\n           ============================================================ */\r\n        .tcl-footer {\r\n          position: relative;\r\n          overflow: hidden;\r\n        }\r\n\r\n        /* Background image layer */\r\n        .tcl-footer__bg {\r\n          position: absolute;\r\n          inset: 0;\r\n          background: url('https://trafficcoplabs.com/wp-content/uploads/2025/12/Untitled-design-10.png') center top / cover no-repeat;\r\n          z-index: 0;\r\n        }\r\n\r\n        /* Dark gradient overlay for readability */\r\n        .tcl-footer__overlay {\r\n          position: absolute;\r\n          inset: 0;\r\n          background: linear-gradient(\r\n            180deg,\r\n            rgba(10, 15, 25, 0.92) 0%,\r\n            rgba(10, 15, 25, 0.88) 50%,\r\n            rgba(10, 15, 25, 0.95) 100%\r\n          );\r\n          z-index: 1;\r\n        }\r\n\r\n        /* Accent stripe at top */\r\n        .tcl-footer__stripe {\r\n          position: relative;\r\n          z-index: 2;\r\n          height: 3px;\r\n          background: linear-gradient(90deg, var(--tcl-orange), #3a7ca5);\r\n        }\r\n\r\n        /* Content wrapper */\r\n        .tcl-footer__content {\r\n          position: relative;\r\n          z-index: 2;\r\n          max-width: 1280px;\r\n          margin: 0 auto;\r\n          padding: 60px 28px 48px;\r\n          display: flex;\r\n          flex-direction: column;\r\n          align-items: center;\r\n          text-align: center;\r\n        }\r\n\r\n        /* ============================================================\r\n           LOGO\r\n           ============================================================ */\r\n        .tcl-footer__logo {\r\n          display: flex;\r\n          align-items: baseline;\r\n          font-family: 'Bebas Neue', sans-serif;\r\n          font-weight: 400;\r\n          font-size: 42px;\r\n          letter-spacing: 0.05em;\r\n          line-height: 1;\r\n          text-transform: uppercase;\r\n          white-space: nowrap;\r\n          -webkit-text-stroke: 0.5px currentColor;\r\n          margin-bottom: 16px;\r\n          transition: opacity var(--tcl-fast) var(--tcl-ease);\r\n        }\r\n\r\n        .tcl-footer__logo:hover {\r\n          opacity: 0.85;\r\n        }\r\n\r\n        .tcl-footer__logo-main {\r\n          color: var(--tcl-logo-cream);\r\n        }\r\n\r\n        .tcl-footer__logo-accent {\r\n          color: var(--tcl-logo-orange);\r\n          margin-left: 0.18em;\r\n        }\r\n\r\n        /* ============================================================\r\n           TAGLINE / LOCATION\r\n           ============================================================ */\r\n        .tcl-footer__location {\r\n          display: flex;\r\n          align-items: center;\r\n          gap: 8px;\r\n          font-size: 14px;\r\n          font-weight: 500;\r\n          color: var(--tcl-text-muted);\r\n          letter-spacing: 0.5px;\r\n          margin-bottom: 32px;\r\n        }\r\n\r\n        .tcl-footer__location-icon {\r\n          width: 16px;\r\n          height: 16px;\r\n          opacity: 0.7;\r\n        }\r\n\r\n        /* ============================================================\r\n           SOCIAL LINKS\r\n           ============================================================ */\r\n        .tcl-footer__socials {\r\n          display: flex;\r\n          align-items: center;\r\n          gap: 20px;\r\n          margin-bottom: 40px;\r\n        }\r\n\r\n        .tcl-footer__social-link {\r\n          display: flex;\r\n          align-items: center;\r\n          justify-content: center;\r\n          width: 48px;\r\n          height: 48px;\r\n          border-radius: 50%;\r\n          background: rgba(255, 255, 255, 0.06);\r\n          border: 1px solid rgba(255, 255, 255, 0.12);\r\n          color: rgba(255, 255, 255, 0.8);\r\n          transition: all var(--tcl-fast) var(--tcl-ease);\r\n        }\r\n\r\n        .tcl-footer__social-link:hover {\r\n          background: var(--tcl-orange);\r\n          border-color: var(--tcl-orange);\r\n          color: var(--tcl-white);\r\n          transform: translateY(-3px);\r\n          box-shadow: 0 8px 24px var(--tcl-orange-glow);\r\n        }\r\n\r\n        .tcl-footer__social-link svg {\r\n          width: 22px;\r\n          height: 22px;\r\n        }\r\n\r\n        /* ============================================================\r\n           DIVIDER\r\n           ============================================================ */\r\n        .tcl-footer__divider {\r\n          width: 100%;\r\n          max-width: 600px;\r\n          height: 1px;\r\n          background: linear-gradient(\r\n            90deg,\r\n            transparent 0%,\r\n            rgba(255, 255, 255, 0.15) 50%,\r\n            transparent 100%\r\n          );\r\n          margin-bottom: 28px;\r\n        }\r\n\r\n        /* ============================================================\r\n           COPYRIGHT\r\n           ============================================================ */\r\n        .tcl-footer__copyright {\r\n          font-size: 13px;\r\n          font-weight: 400;\r\n          color: rgba(255, 255, 255, 0.4);\r\n          letter-spacing: 0.3px;\r\n        }\r\n\r\n        .tcl-footer__copyright-year {\r\n          color: rgba(255, 255, 255, 0.55);\r\n        }\r\n\r\n        /* ============================================================\r\n           RESPONSIVE\r\n           ============================================================ */\r\n        @media (max-width: 640px) {\r\n          .tcl-footer__content {\r\n            padding: 48px 24px 40px;\r\n          }\r\n\r\n          .tcl-footer__logo {\r\n            font-size: 32px;\r\n          }\r\n\r\n          .tcl-footer__socials {\r\n            gap: 16px;\r\n          }\r\n\r\n          .tcl-footer__social-link {\r\n            width: 44px;\r\n            height: 44px;\r\n          }\r\n\r\n          .tcl-footer__social-link svg {\r\n            width: 20px;\r\n            height: 20px;\r\n          }\r\n        }\r\n      </style>\r\n\r\n      <footer class=\"tcl-footer\">\r\n        <!-- Background image -->\r\n        <div class=\"tcl-footer__bg\" aria-hidden=\"true\"></div>\r\n        \r\n        <!-- Dark overlay -->\r\n        <div class=\"tcl-footer__overlay\" aria-hidden=\"true\"></div>\r\n        \r\n        <!-- Top accent stripe -->\r\n        <div class=\"tcl-footer__stripe\" aria-hidden=\"true\"></div>\r\n\r\n        <!-- Content -->\r\n        <div class=\"tcl-footer__content\">\r\n          \r\n          <!-- Logo -->\r\n          <a href=\"/\" class=\"tcl-footer__logo\" aria-label=\"Traffic Cop Labs Home\">\r\n            <span class=\"tcl-footer__logo-main\">TRAFFIC COP</span>\r\n            <span class=\"tcl-footer__logo-accent\">LABS</span>\r\n          </a>\r\n\r\n          <!-- Location -->\r\n          <div class=\"tcl-footer__location\">\r\n            <svg class=\"tcl-footer__location-icon\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\r\n              <path d=\"M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z\"/>\r\n              <circle cx=\"12\" cy=\"10\" r=\"3\"/>\r\n            </svg>\r\n            HQ'd in Port St. Lucie, Florida\r\n          </div>\r\n\r\n          <!-- Social Links -->\r\n          <div class=\"tcl-footer__socials\">\r\n            <!-- Facebook -->\r\n            <a href=\"https://www.facebook.com/TrafficCopLabs/\" class=\"tcl-footer__social-link\" aria-label=\"Facebook\" target=\"_blank\" rel=\"noopener noreferrer\">\r\n              <svg viewBox=\"0 0 24 24\" fill=\"currentColor\">\r\n                <path d=\"M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953